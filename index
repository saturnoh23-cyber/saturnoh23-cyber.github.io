function getSpineColors(){
  const st=getComputedStyle(document.documentElement);
  const p2=st.getPropertyValue('--p2').trim();
  const p3=st.getPropertyValue('--p3').trim();
  const p4=st.getPropertyValue('--p4').trim();
  const p5=st.getPropertyValue('--p5').trim();
  const card=st.getPropertyValue('--card').trim();
  const border=st.getPropertyValue('--border').trim();
  return [p3,p4,p2,p5,
    adjustColor(p3,30),adjustColor(p4,-20),adjustColor(p2,15),
    adjustColor(p5,25),adjustColor(p3,-15),adjustColor(p4,35),
    adjustColor(p2,-10),adjustColor(p5,-25)];
}
function adjustColor(hex,amount){
  try{
    hex=hex.trim();
    if(!hex.startsWith('#'))return hex;
    hex=hex.replace('#','');
    if(hex.length===3)hex=hex.split('').map(x=>x+x).join('');
    if(hex.length!==6)return '#'+hex;
    const r=Math.min(255,Math.max(0,parseInt(hex.slice(0,2),16)+amount));
    const g=Math.min(255,Math.max(0,parseInt(hex.slice(2,4),16)+amount));
    const b=Math.min(255,Math.max(0,parseInt(hex.slice(4,6),16)+amount));
    return '#'+r.toString(16).padStart(2,'0')+g.toString(16).padStart(2,'0')+b.toString(16).padStart(2,'0');
  }catch{return hex||'#cccccc';}
}
function buildShelfCard(items){
  const div=document.createElement('div');
  div.className='diario-card';
  if(!items.length){
    div.innerHTML=`<div class="diario-card-title">📚 Biblioteca visual</div><div style="text-align:center;padding:1.2rem;color:var(--text3);font-size:.8rem;">Aún no has marcado nada como leído</div>`;
    return div;
  }
  const colors=getSpineColors();
  const SHELF_SIZE=14;
  const rows=[];
  for(let i=0;i<items.length;i+=SHELF_SIZE)rows.push(items.slice(i,i+SHELF_SIZE));
  const shelvesHtml=rows.map(row=>{
    const spines=row.map((it,idx)=>{
      const colorIdx=((it.title.charCodeAt(0)||0)+idx)%colors.length;
      const color=colors[colorIdx];
      const h=52+Math.abs((it.title.charCodeAt(3)||0)%28);
      const w=16+Math.abs((it.title.charCodeAt(1)||0)%10);
      return `<div class="shelf-spine" style="background:${color};height:${h}px;width:${w}px;border:1.5px solid rgba(0,0,0,0.35);box-shadow:inset -2px 0 3px rgba(0,0,0,0.15),inset 1px 0 2px rgba(255,255,255,0.2);" title="${it.title}">
        <span class="shelf-spine-text">${it.title}</span>
      </div>`;
    }).join('');
    return `<div class="shelf-row">${spines}</div>`;
  }).join('');
  div.innerHTML=`<div class="diario-card-title">📚 Biblioteca visual <span>${items.length} leídos</span></div>
    <div class="shelf-unit">${shelvesHtml}</div>`;
  return div;
}

