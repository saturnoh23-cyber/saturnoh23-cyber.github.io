function render(){
  updateStats();
  const q=document.getElementById('searchInput').value.toLowerCase();
  const grid=document.getElementById('bookGrid');
  grid.className=view==='list'?'list-view':`cols-${view}`;
  const filtered=BOOKS.filter(b=>{
    const st=STATE[b.id];
    let mf=true;
    if(filter==='all') mf=true;
    else if(filter==='recent'){const a=b.addedAt?new Date(b.addedAt):null;mf=a&&a>=new Date(Date.now()-7*24*60*60*1000);}
    else if(filter.startsWith('emit-')) mf=st.emission===filter.replace('emit-','');
    else if(filter.startsWith('type-')) mf=(st.type||'manhwa')===filter.replace('type-','');
    else if(filter==='favorite') mf=!!st.favorite;
    else if(filter==='hated') mf=!!st.hated;
    else mf=st.status===filter;
    return mf&&(!q||b.title.toLowerCase().includes(q));
  });
  if(!filtered.length){grid.innerHTML=`<div class="empty"><div class="big">🌸</div>Ningún título coincide</div>`;return;}
  grid.innerHTML=filtered.map((b,i)=>buildCardHTML(b,i)).join('');
}

function renderOneCard(id){
  const el=document.querySelector(`.book-card[data-id="${id}"]`);
  if(!el){render();return;}
  const b=BOOKS.find(x=>x.id===id);
  if(!b){render();return;}
  const i=BOOKS.findIndex(x=>x.id===id);
  const tmp=document.createElement('div');
  tmp.innerHTML=buildCardHTML(b,i);
  const newEl=tmp.firstElementChild;

  newEl.style.animation='none';
  newEl.style.animationDelay='0s';
  el.replaceWith(newEl);
  updateStats();
}

