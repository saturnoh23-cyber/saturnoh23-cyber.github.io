const PDF_SECTIONS=[
  {id:'grid',   label:'📚 Cuadrícula de manga y libros', defaultOn:false},
  {id:'review', label:'📝 Reseña individual',            defaultOn:true},
  {id:'tracker',label:'📅 Tracker de lectura diaria',    defaultOn:false},
  {id:'bingo',  label:'🎯 Bingo literario',              defaultOn:false},
  {id:'stats',  label:'📊 Estadísticas',                 defaultOn:false},
];
let _pdfSectionOrder=PDF_SECTIONS.map(s=>s.id);
let _pdfSectionOn={grid:false,review:true,tracker:false,bingo:false,stats:false};
let _pdfDragId=null;

function renderPdfSectionOrder(){
  const el=document.getElementById('pdfSectionOrder');
  if(!el)return;
  el.innerHTML='';
  _pdfSectionOrder.forEach((id,i)=>{
    const sec=PDF_SECTIONS.find(s=>s.id===id);
    if(!sec)return;
    const on=_pdfSectionOn[id];
    const div=document.createElement('div');
    div.dataset.pdfSec=id;
    div.setAttribute('draggable','true');
    div.style.cssText=`display:flex;align-items:center;gap:.55rem;padding:.42rem .65rem;border-radius:10px;border:2px solid ${on?'var(--p3)':'var(--border)'};background:${on?'var(--p1)':'var(--card)'};cursor:grab;user-select:none;touch-action:none;transition:border-color .15s,background .15s;`;
    div.innerHTML=`
      <span style="color:var(--text3);font-size:.9rem;flex-shrink:0;">☰</span>
      <span style="font-size:.78rem;flex:1;color:${on?'var(--p5)':'var(--text3)'};font-weight:${on?600:400};">${sec.label}</span>
      <span style="font-size:.65rem;color:var(--text3);flex-shrink:0;">${i+1}</span>
      <button onclick="event.stopPropagation();_pdfSectionOn['${id}']=!_pdfSectionOn['${id}'];renderPdfSectionOrder();"
        style="flex-shrink:0;padding:.2rem .5rem;border-radius:20px;border:1.5px solid ${on?'var(--p3)':'var(--border)'};background:${on?'var(--p3)':'transparent'};color:${on?'#fff':'var(--text3)'};font-size:.65rem;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;">
        ${on?'✓ ON':'OFF'}
      </button>`;
    div.addEventListener('dragstart',e=>{_pdfDragId=id;div.style.opacity='.45';e.dataTransfer.effectAllowed='move';});
    div.addEventListener('dragend',()=>{div.style.opacity='1';_pdfDragId=null;});
    div.addEventListener('dragover',e=>{e.preventDefault();div.style.transform='scale(1.02)';});
    div.addEventListener('dragleave',()=>{div.style.transform='';});
    div.addEventListener('drop',e=>{
      e.preventDefault();div.style.transform='';
      if(!_pdfDragId||_pdfDragId===id)return;
      const from=_pdfSectionOrder.indexOf(_pdfDragId);
      const to=_pdfSectionOrder.indexOf(id);
      if(from<0||to<0)return;
      _pdfSectionOrder.splice(from,1);_pdfSectionOrder.splice(to,0,_pdfDragId);
      renderPdfSectionOrder();
    });
    div.addEventListener('touchstart',e=>{_pdfDragId=id;div.style.opacity='.6';},{passive:true});
    div.addEventListener('touchend',e=>{
      div.style.opacity='1';
      const t=e.changedTouches[0];
      const tgt=document.elementFromPoint(t.clientX,t.clientY)?.closest('[data-pdf-sec]');
      const tid=tgt?.dataset.pdfSec;
      if(tid&&tid!==_pdfDragId){
        const from=_pdfSectionOrder.indexOf(_pdfDragId);
        const to=_pdfSectionOrder.indexOf(tid);
        if(from>=0&&to>=0){_pdfSectionOrder.splice(from,1);_pdfSectionOrder.splice(to,0,_pdfDragId);}
        renderPdfSectionOrder();
      }
      _pdfDragId=null;
    });
    el.appendChild(div);
  });
}

