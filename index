let _editCoverData=null;
function handleCoverFile(input){
  const file=input.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=e=>{
    const img=new Image();
    img.onload=()=>{
      const maxW=300,maxH=450;let w=img.width,h=img.height;
      if(w>maxW){h=Math.round(h*maxW/w);w=maxW;}if(h>maxH){w=Math.round(w*maxH/h);h=maxH;}
      const canvas=document.createElement('canvas');canvas.width=w;canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      _editCoverData=canvas.toDataURL('image/jpeg',.75);showCoverPreview(_editCoverData);
    };img.src=e.target.result;
  };reader.readAsDataURL(file);
