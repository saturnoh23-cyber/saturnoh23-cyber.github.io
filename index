function buildAbcCard(items){
  const div=document.createElement('div');
  div.className='diario-card';
  const yearNow=new Date().getFullYear();
  const abcYear=_abcYear||yearNow;

  const yearsInData=new Set(items.map(it=>it.finishDate?.slice(0,4)).filter(Boolean));
  yearsInData.add(String(yearNow));
  const yearList=[...yearsInData].map(Number).sort((a,b)=>b-a);
  if(!yearList.includes(abcYear))yearList.push(abcYear);
  yearList.sort((a,b)=>b-a);

  const filtered=items.filter(it=>{
    if(!it.finishDate)return false;
    return it.finishDate.startsWith(String(abcYear));
  });
  const map={};
  filtered.forEach(it=>{
    const first=it.title.replace(/^(El |La |Los |Las |Un |Una |The )/i,'').toUpperCase()[0];
    if(first&&!map[first])map[first]=it.title;
  });
  const cells=ALPHABET.map(l=>`<div class="abc-cell">
    <span class="abc-letter">${l}</span>
    <span class="abc-value${map[l]?'':' abc-empty'}">${map[l]||'—'}</span>
  </div>`).join('');

