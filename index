function setView(v){
  view=v;
  const grid=document.getElementById('bookGrid');
  ['col1Btn','col2Btn','col3Btn','colAutoBtn','listBtn'].forEach(id=>{
    const el=document.getElementById(id);if(el)el.classList.remove('active');
  });
