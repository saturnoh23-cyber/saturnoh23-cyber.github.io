function updateRestPreview(){
  const active=parseInt(document.getElementById('editRestActive')?.value)||0;
  const pause=parseInt(document.getElementById('editRestPause')?.value)||0;
  const startVal=document.getElementById('editRestStart')?.value;
  const el=document.getElementById('editRestPreview');
  if(!el)return;
  if(!active||!pause){el.textContent='';return;}
  if(!startVal){el.textContent='⚠️ Indica la fecha de inicio del ciclo';return;}
  const start=new Date(startVal);start.setHours(0,0,0,0);
  const today=new Date();today.setHours(0,0,0,0);
  const diffDays=Math.floor((today-start)/(1000*60*60*24));
  if(diffDays<0){el.textContent='⚠️ La fecha de inicio es en el futuro';return;}
  const cycleLen=(active+pause)*7;
  const posInCycle=diffDays%cycleLen;
  const weekInCycle=Math.floor(posInCycle/7)+1;
  const isResting=posInCycle>=active*7;
  const daysLeft=isResting?(cycleLen-posInCycle):(active*7-posInCycle);
  if(isResting){
    el.innerHTML=`😴 Ahora en pausa · Retoma en <strong>${daysLeft}</strong> día${daysLeft!==1?'s':''}`;
  } else {
    el.innerHTML=`✅ Semana activa ${weekInCycle}/${active} · Pausa en <strong>${daysLeft}</strong> día${daysLeft!==1?'s':''}`;
  }
}
