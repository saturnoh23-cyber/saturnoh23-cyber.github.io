function generatePdf(){
  const filterVal=document.getElementById('pdfFilter').value;
  const selYear=parseInt(document.getElementById('pdfYear').value||new Date().getFullYear());
  const selMonth=parseInt(document.getElementById('pdfMonth').value);
  const MN=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

  const incRead=document.getElementById('tog-pdfRead').classList.contains('active');
  const incReading=document.getElementById('tog-pdfReading').classList.contains('active');
  const incPaused=document.getElementById('tog-pdfPaused').classList.contains('active');
  const allowed=[];if(incRead)allowed.push('read');if(incReading)allowed.push('reading');if(incPaused)allowed.push('paused');

  const activeSections=_pdfSectionOrder.filter(id=>_pdfSectionOn[id]);
  const incGrid=activeSections.includes('grid');
  const incReview=activeSections.includes('review');
  const incTracker=activeSections.includes('tracker');
  const incBingo=activeSections.includes('bingo');
  const incStats=activeSections.includes('stats');

  if(!activeSections.length){showToast('⚠️ Activa al menos una sección');return;}
  if((incGrid||incReview)&&!allowed.length){showToast('⚠️ Selecciona al menos un estado de lectura');return;}

  let mangaItems=BOOKS.filter(b=>allowed.includes(STATE[b.id]?.status));
  let bookItems=BOOKS_LIB.filter(b=>allowed.includes(BOOKS_STATE[b.id]?.status));
  let periodLabel='Todo';
  if(filterVal==='year'){
    mangaItems=mangaItems.filter(b=>{const d=STATE[b.id].finishDate||b.addedAt;return d&&new Date(d).getFullYear()===selYear;});
    bookItems=bookItems.filter(b=>{const d=BOOKS_STATE[b.id].finishDate||b.addedAt;return d&&new Date(d).getFullYear()===selYear;});
    periodLabel=`Año ${selYear}`;
  } else if(filterVal==='month'){
    mangaItems=mangaItems.filter(b=>{const d=STATE[b.id].finishDate||b.addedAt;if(!d)return false;const dt=new Date(d);return dt.getFullYear()===selYear&&dt.getMonth()===selMonth;});
    bookItems=bookItems.filter(b=>{const d=BOOKS_STATE[b.id].finishDate||b.addedAt;if(!d)return false;const dt=new Date(d);return dt.getFullYear()===selYear&&dt.getMonth()===selMonth;});
    periodLabel=`${MN[selMonth]} ${selYear}`;
  }

  const ratingPrefs=getRatingPrefs();
  const starRow=r=>{let s='';for(let i=1;i<=5;i++)s+=`<span style="color:${i<=r?'#ff8fab':'#f5d0db'};font-size:13px;">★</span>`;return s;};
  const emoRow=(val,icon)=>{let s=`<span style="font-size:10px;margin-right:2px;">${icon}</span>`;for(let i=1;i<=5;i++)s+=`<span style="color:${i<=val?'#ff8fab':'#f5d0db'};font-size:11px;">●</span>`;return s;};
  const buildJournalRating=st=>{
    let html='';
    if(ratingPrefs.stars!==false) html+=`<div style="margin-bottom:3px;">${starRow(st.rating||0)}</div>`;
    if(ratingPrefs.cry&&(st.cry||0)>0) html+=`<div style="margin-bottom:2px;">${emoRow(st.cry,'😢')}</div>`;
    if(ratingPrefs.laugh&&(st.laugh||0)>0) html+=`<div style="margin-bottom:2px;">${emoRow(st.laugh,'😂')}</div>`;
    if(ratingPrefs.spicy&&(st.spicy||0)>0) html+=`<div style="margin-bottom:2px;">${emoRow(st.spicy,'🌶️')}</div>`;
    return html;
  };
  const heartBorder=`<div style="text-align:center;font-size:11px;color:#ffb3c6;letter-spacing:4px;margin:6px 0;">♡ · ♡ · ♡ · ♡ · ♡ · ♡ · ♡ · ♡ · ♡</div>`;

  const TAB_COLORS={
    grid:'#ff8fab', review:'#c084fc', tracker:'#67e8f9',
    bingo:'#fbbf24', stats:'#86efac'
  };
  const TAB_LABELS={
    grid:'📚 Cuadrícula', review:'📝 Reseñas',
    tracker:'📅 Tracker', bingo:'🎯 Bingo', stats:'📊 Stats'
  };

  const buildSideTabs=(currentId)=>{
    const tabHeight=Math.floor(700/activeSections.length);
    const tabs=activeSections.map((id,i)=>{
      const col=TAB_COLORS[id]||'#ff8fab';
      const isCur=id===currentId;
      return `<a href="#sec-${id}" style="display:flex;align-items:center;justify-content:center;height:${tabHeight}px;background:${isCur?col:'#fff0f4'};border-left:${isCur?'4px':'2px'} solid ${col};writing-mode:vertical-rl;text-orientation:mixed;font-size:${isCur?'9.5':'8.5'}px;font-weight:${isCur?700:500};color:${isCur?'#fff':col};text-decoration:none;padding:6px 3px;letter-spacing:.5px;transition:all .2s;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${TAB_LABELS[id]}</a>`;
    }).join('');
    return `<div style="position:fixed;left:0;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;width:28px;border-radius:0 8px 8px 0;overflow:hidden;box-shadow:2px 0 8px rgba(255,143,171,.2);z-index:100;">${tabs}</div>`;
  };

  const wrapPage=(content, secId, extraStyle='')=>{
    return `<div style="position:relative;page-break-after:always;padding:18px 20px 18px 44px;box-sizing:border-box;min-height:96vh;${extraStyle}">
      ${buildSideTabs(secId)}
      ${content}
    </div>`;
  };

  const secHeader=(icon,title,col)=>`
