function checkBingoWins(b){
  const sz=b.size;
  const m=b.cells.map(c=>c.marked);
  let wins=0;
  for(let r=0;r<sz;r++){if(Array.from({length:sz},(_,c)=>m[r*sz+c]).every(Boolean))wins++;}
  for(let c=0;c<sz;c++){if(Array.from({length:sz},(_,r)=>m[r*sz+c]).every(Boolean))wins++;}
  if(Array.from({length:sz},(_,i)=>m[i*sz+i]).every(Boolean))wins++;
  if(Array.from({length:sz},(_,i)=>m[i*sz+(sz-1-i)]).every(Boolean))wins++;
  return wins;
}
