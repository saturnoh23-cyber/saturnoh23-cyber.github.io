function importBackup(input){
  const file=input.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const data=JSON.parse(e.target.result);

      const hasManga=data.books&&data.state;
      const hasBooks=data.booksLib&&data.booksState;
      if(!hasManga&&!hasBooks){showToast('❌ Archivo no válido');return;}
      if(!confirm('¿Restaurar respaldo? Se reemplazarán los datos actuales.')){input.value='';return;}

      if(hasManga){
        BOOKS=data.books;
        STATE={};
        Object.keys(data.state).forEach(id=>{STATE[id]=Object.assign(defaultEntry(),data.state[id]);});

        BOOKS.forEach(b=>{if(!STATE[b.id])STATE[b.id]=defaultEntry();});
      }

      if(hasBooks){
        BOOKS_LIB=data.booksLib;
        BOOKS_STATE={};
        Object.keys(data.booksState).forEach(id=>{BOOKS_STATE[id]=Object.assign(defaultBookEntry(),data.booksState[id]);});
        BOOKS_LIB.forEach(b=>{if(!BOOKS_STATE[b.id])BOOKS_STATE[b.id]=defaultBookEntry();});
      }
      saveBooks();save();saveBooksLib();saveBooksState();

      if(data.readingLog)saveReadingLog(data.readingLog);
      if(data.bingos)saveBingos(data.bingos);
      if(data.diarioPrefs)saveDiarioPrefs(data.diarioPrefs);
      if(data.tabOrder)saveTabOrder(data.tabOrder);
      if(data.palette)localStorage.setItem('tbr-palette',data.palette);
      if(data.fieldPrefs)localStorage.setItem('tbr-field-prefs',JSON.stringify(data.fieldPrefs));
      if(data.bookFieldPrefs)localStorage.setItem('tbr-book-field-prefs',JSON.stringify(data.bookFieldPrefs));
      if(data.statsPrefs)localStorage.setItem('tbr-stats-prefs',JSON.stringify(data.statsPrefs));

      loadSavedPalette();applyTabOrder();
      renderTodayBanner();render();renderBooks();
      showToast(`✨ Datos restaurados — ${BOOKS.length} manga · ${BOOKS_LIB.length} libros`);
    }catch(err){showToast('❌ Error al leer el archivo');}
    input.value='';
  };reader.readAsText(file);
}

