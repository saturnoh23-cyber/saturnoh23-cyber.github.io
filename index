const DEFAULT_TABS=[
  {id:'manga',label:'📚 Manga'},
  {id:'books',label:'📖 Libros'},
  {id:'stats',label:'📊 Stats'},
  {id:'bingo',label:'🎯 Bingo'},
  {id:'diario',label:'📝 Diario'},
  {id:'custom',label:'🎨 Estilo'},
  {id:'settings',label:'⚙️ Datos'},
];
function loadTabOrder(){
  try{const saved=JSON.parse(localStorage.getItem("tbr-tab-order")||"null");if(saved&&Array.isArray(saved)&&saved.length===DEFAULT_TABS.length)return saved;}catch{}
  return DEFAULT_TABS.map(t=>t.id);
}
function saveTabOrder(order){localStorage.setItem("tbr-tab-order",JSON.stringify(order));}
function applyTabOrder(){
  const order=loadTabOrder();const bar=document.querySelector(".main-tabs");if(!bar)return;
  const tabs=Array.from(bar.querySelectorAll(".main-tab"));const tabMap={};
  tabs.forEach(t=>{const match=DEFAULT_TABS.find(d=>t.id==="tab"+d.id[0].toUpperCase()+d.id.slice(1));if(match)tabMap[match.id]=t;});
  order.forEach(id=>{if(tabMap[id])bar.appendChild(tabMap[id]);});
}
let _dragTabId=null;
function renderTabOrderList(){
  const el=document.getElementById('tabOrderList');if(!el)return;
  const order=loadTabOrder();
  el.innerHTML='';
  order.forEach((id,i)=>{
    const t=DEFAULT_TABS.find(d=>d.id===id);if(!t)return;
    const div=document.createElement('div');
    div.setAttribute('draggable','true');
    div.dataset.tabId=id;
    div.style.cssText='display:flex;align-items:center;gap:.5rem;padding:.45rem .7rem;background:var(--p1);border:1.5px solid var(--border);border-radius:9px;cursor:grab;user-select:none;margin-bottom:.28rem;transition:opacity .15s,transform .15s;touch-action:none;';
    div.innerHTML=`<span style="color:var(--text3);font-size:.85rem;">☰</span><span style="font-size:.82rem;flex:1;">${t.label}</span><span style="font-size:.65rem;color:var(--text3);">${i+1}</span>`;
    div.addEventListener('dragstart',e=>{_dragTabId=id;div.style.opacity='.45';e.dataTransfer.effectAllowed='move';});
    div.addEventListener('dragend',()=>{div.style.opacity='1';_dragTabId=null;});
    div.addEventListener('dragover',e=>{e.preventDefault();e.dataTransfer.dropEffect='move';div.style.transform='scale(1.02)';});
    div.addEventListener('dragleave',()=>{div.style.transform='';});
    div.addEventListener('drop',e=>{
      e.preventDefault();div.style.transform='';
      if(!_dragTabId||_dragTabId===id)return;
      const ord=loadTabOrder();
      const from=ord.indexOf(_dragTabId);const to=ord.indexOf(id);
      if(from<0||to<0)return;
      ord.splice(from,1);ord.splice(to,0,_dragTabId);
      saveTabOrder(ord);applyTabOrder();renderTabOrderList();
    });
    let touchStartY=0,touchId=null;
    div.addEventListener('touchstart',e=>{touchId=id;_dragTabId=id;touchStartY=e.touches[0].clientY;div.style.opacity='.6';},{passive:true});
    div.addEventListener('touchend',e=>{
      div.style.opacity='1';
      const touch=e.changedTouches[0];
      const target=document.elementFromPoint(touch.clientX,touch.clientY);
      const targetDiv=target?.closest('[data-tab-id]');
      const targetId=targetDiv?.dataset.tabId;
      if(targetId&&targetId!==_dragTabId){
        const ord=loadTabOrder();
        const from=ord.indexOf(_dragTabId);const to=ord.indexOf(targetId);
        if(from>=0&&to>=0){ord.splice(from,1);ord.splice(to,0,_dragTabId);}
        saveTabOrder(ord);applyTabOrder();renderTabOrderList();
      }
      _dragTabId=null;
    });
    el.appendChild(div);
  });
}
function tabDragOver(e){e.preventDefault();}
function tabDrop(e,targetId){e.preventDefault();}
function resetTabOrder(){localStorage.removeItem('tbr-tab-order');applyTabOrder();renderTabOrderList();showToast('↩ Orden restablecido');}

document.addEventListener('DOMContentLoaded',()=>{

  try{
    const prefs=JSON.parse(localStorage.getItem('tbr-field-prefs')||'{}');
    let changed=false;
    ['cover','extras','sinopsis'].forEach(f=>{if(!(f in prefs)){prefs[f]=true;changed=true;}});
    if(changed)localStorage.setItem('tbr-field-prefs',JSON.stringify(prefs));
  }catch{}
  loadSavedPalette();
  applyTheme();
  loadFieldPrefs();
  loadStatsPrefs();
  loadBookFieldPrefs();
  loadBookView();
  loadDiarioSectionToggles();
  loadRatingPrefsToggles();
  render();
  applyTabOrder();
  renderTodayBanner();
  document.getElementById('pdfFilter').addEventListener('change',togglePdfRows);
});

if('serviceWorker' in navigator){
  window.addEventListener('load',()=>navigator.serviceWorker.register('sw.js').catch(()=>{}));
}

document.addEventListener('click',e=>{
  const wrap=document.getElementById('bookGenreDropWrap');
  if(wrap&&!wrap.contains(e.target))closeBookGenreDrop();
});

</script>
