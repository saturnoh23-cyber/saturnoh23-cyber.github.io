function spin(){
  const unread=BOOKS.filter(b=>STATE[b.id].status==='unread');
  if(!unread.length){document.getElementById('resultBox').textContent='¡Ya leíste todo! 🎉';return;}
  if(spinning)return;
  spinning=true;document.getElementById('spinBtn').disabled=true;
  const winner=unread[Math.floor(Math.random()*unread.length)];
  const titles=unread.map(b=>b.title);
  let elapsed=0,idx=0,lastT=null;
  function step(ts){
    if(!lastT)lastT=ts;
    const delta=ts-lastT;elapsed+=delta;lastT=ts;
    if(delta>=(55+elapsed/2800*380)*.75){idx=(idx+1)%titles.length;document.getElementById('rouletteTitle').textContent=titles[idx];lastT=ts;}
    if(elapsed<2800){rafId=requestAnimationFrame(step);}
    else{
      document.getElementById('rouletteTitle').textContent=winner.title;
      const rb=document.getElementById('resultBox');
      rb.textContent=`✨ ${winner.title} ✨`;rb.classList.remove('pop');void rb.offsetWidth;rb.classList.add('pop');
      spinning=false;document.getElementById('spinBtn').disabled=false;
    }
  }
  rafId=requestAnimationFrame(step);
}

