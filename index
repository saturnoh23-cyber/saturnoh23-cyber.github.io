  BOOK_FIELDS.forEach(f=>{const el=document.getElementById(`btog-${f}`);if(el)prefs[f]=el.checked;});
  localStorage.setItem('tbr-book-field-prefs',JSON.stringify(prefs));
  renderBooks();
}
function getBookFieldPref(f){
  const prefs=JSON.parse(localStorage.getItem('tbr-book-field-prefs')||'{}');
  return prefs[f]!==false;
}
function setBookFilter(f,btn){
  bookFilter=f;
  document.querySelectorAll('#sectionBooks .filter-btn').forEach(b=>b.classList.remove('active'));
  if(btn&&btn.classList.contains('filter-btn'))btn.classList.add('active');
  renderBooks();
}

function renderBooks(){
  const grid=document.getElementById('bookGrid2');if(!grid)return;
  grid.className=bookView==='list'?'list-view':`cols-${bookView}`;
  renderBookGenreChips();
  const q=(document.getElementById('searchBooksInput')?.value||'').toLowerCase().trim();
  const cutoff=new Date(Date.now()-7*24*60*60*1000);
  const filtered=BOOKS_LIB.filter(b=>{
    const st=BOOKS_STATE[b.id];
    let mf=true;
    if(bookFilter==='all')mf=true;
    else if(bookFilter==='recent')mf=b.addedAt&&new Date(b.addedAt)>=cutoff;
    else if(bookFilter.startsWith('format-'))mf=(st.format||'fisico')===bookFilter.replace('format-','');
    else if(bookFilter==='saga')mf=!!(st?.saga&&st.saga.trim()!=='');
    else if(bookFilter==='favorite')mf=!!st.favorite;
    else if(bookFilter==='hated')mf=!!st.hated;
    else if(bookFilter==='trilogy'){
      const saga=st?.saga?.trim();
      if(!saga){mf=false;}
      else{const cnt=BOOKS_LIB.filter(x=>BOOKS_STATE[x.id]?.saga?.trim()===saga).length;mf=cnt>=3;}
    }
    else if(bookFilter.startsWith('genre-')){const fg=bookFilter.replace('genre-','').toLowerCase();mf=(st.genre||'').split(/[,;/]+/).map(x=>x.trim().toLowerCase()).includes(fg);}
    else mf=st.status===bookFilter;
    return mf&&(!q||b.title.toLowerCase().includes(q)||(st.author||'').toLowerCase().includes(q));
  });

  const cnt={unread:0,reading:0,read:0,paused:0};
  BOOKS_LIB.forEach(b=>{const s=BOOKS_STATE[b.id]?.status||'unread';if(cnt[s]!==undefined)cnt[s]++;});
  const favCnt=BOOKS_LIB.filter(b=>BOOKS_STATE[b.id]?.favorite).length;
  const hateCnt=BOOKS_LIB.filter(b=>BOOKS_STATE[b.id]?.hated).length;
  const triCnt=(()=>{const sagaMap={};BOOKS_LIB.forEach(b=>{const s=BOOKS_STATE[b.id]?.saga?.trim();if(s)sagaMap[s]=(sagaMap[s]||0)+1;});return Object.values(sagaMap).filter(n=>n>=3).length;})();
  const total=BOOKS_LIB.length;
  const sagas=new Set(BOOKS_LIB.map(b=>BOOKS_STATE[b.id]?.saga).filter(s=>s&&s.trim()!==''));
  const subtitleEl=document.getElementById('booksSubtitle');
  if(subtitleEl)subtitleEl.textContent=`${total} libro${total!==1?'s':''} · ${sagas.size} saga${sagas.size!==1?'s':''} detectada${sagas.size!==1?'s':''}`;
  const hdrGrid=document.getElementById('booksHdrGrid');
  if(hdrGrid){
    const colors={total:'var(--p4)',unread:'#a78bfa',reading:'#f59e0b',read:'#34d399',paused:'#60a5fa',sagas:'#f472b6'};
    const items=[
      {num:total,     label:'TOTAL',   col:colors.total,  filter:'all'},
      {num:cnt.unread,label:'TBR',      col:colors.unread, filter:'unread'},
      {num:cnt.reading,label:'LEYENDO',col:colors.reading,filter:'reading'},
      {num:cnt.read,  label:'LEÍDOS',  col:colors.read,   filter:'read'},
      {num:cnt.paused,label:'PAUSADOS',col:colors.paused, filter:'paused'},
      {num:sagas.size,label:'SAGAS',   col:colors.sagas,  filter:'saga'},
      {num:favCnt,    label:'FAV ⭐',    col:'#d97706',     filter:'favorite'},
      {num:hateCnt,   label:'ODIADOS',   col:'#dc2626',     filter:'hated'},
      {num:triCnt,    label:'TRILOGÍAS', col:'#8b5cf6',     filter:'trilogy'},
    ];
    hdrGrid.innerHTML=items.map(it=>`
      <div class="books-hdr-box" onclick="setBookFilterFromPanel('${it.filter}',this)">
        <span class="books-hdr-num" style="color:${it.col}">${it.num}</span>
        <span class="books-hdr-label">${it.label}</span>
      </div>`).join('');
  }
  if(!filtered.length){grid.innerHTML=`<div class="empty"><div class="big">📖</div>Ningún libro encontrado</div>`;return;}
  grid.innerHTML=filtered.map((b,i)=>{
    const st=BOOKS_STATE[b.id];
    const num=BOOKS_LIB.findIndex(x=>x.id===b.id)+1;
    const bR=getBookFieldPref('rating'),bA=getBookFieldPref('author'),bG=getBookFieldPref('genre');
    const bSaga=getBookFieldPref('saga'),bPg=getBookFieldPref('pages'),bFmt=getBookFieldPref('format');
    const bSt=getBookFieldPref('status'),bCov=getBookFieldPref('cover'),bFd=getBookFieldPref('finishdate');
    const stars=[1,2,3,4,5].map(n=>`<span onclick="setBookRating(${b.id},${n})" style="cursor:pointer;font-size:.95rem;color:${n<=st.rating?'#f59e0b':'var(--border)'};transition:color .12s;">★</span>`).join('');
    const favBtnsB=`<div style="display:flex;gap:.35rem;flex-wrap:wrap;margin-top:.3rem;">
      <button onclick="event.stopPropagation();toggleFav(${b.id},false)" style="display:flex;align-items:center;gap:.3rem;padding:.28rem .65rem;border-radius:20px;border:2px solid ${st.favorite?'#d97706':'var(--border)'};background:${st.favorite?'#fef3c7':'transparent'};color:${st.favorite?'#92400e':'var(--text3)'};font-size:.72rem;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;"><span style="font-size:.85rem;">⭐</span>${st.favorite?'¡Favorito!':'Favorito'}</button>
      <button onclick="event.stopPropagation();toggleHated(${b.id},false)" style="display:flex;align-items:center;gap:.3rem;padding:.28rem .65rem;border-radius:20px;border:2px solid ${st.hated?'#dc2626':'var(--border)'};background:${st.hated?'#fee2e2':'transparent'};color:${st.hated?'#991b1b':'var(--text3)'};font-size:.72rem;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;"><span style="font-size:.85rem;">💔</span>${st.hated?'¡No me gustó!':'No me gustó'}</button>
    </div>`;
    const sL={unread:'Sin leer',reading:'Leyendo',read:'Leído',paused:'Pausado'};
    const statusBtns=['unread','reading','read','paused'].map(s=>`<button class="status-btn s-${s}${st.status===s?' active':''}" onclick="setBookStatus(${b.id},'${s}')">${sL[s]}</button>`).join('');
    return `<div class="book-card book-mode" style="animation-delay:${i*.04}s">
      <div class="card-actions">
        <button class="delete-btn" onclick="deleteBookDirect(${b.id})">🗑️</button>
      </div>
      ${bCov?(st.cover
        ?`<img class="card-cover" src="${st.cover}" alt="portada" title="Toca para cambiar portada" style="cursor:pointer;" onclick="event.stopPropagation();triggerCoverUpload(${b.id},'books')">`
        :`<div class="cover-placeholder" style="cursor:pointer;" onclick="event.stopPropagation();triggerCoverUpload(${b.id},'books')"><span>📖</span><p>Toca para añadir portada</p></div>`):''}
      <div class="card-top" onclick="openBookDetailModal(${b.id})" style="cursor:pointer;">
        <span class="card-num">#${num}</span>
        <div style="flex:1;min-width:0;">
          <div class="card-title">${b.title}</div>
          <div style="display:flex;gap:.25rem;flex-wrap:wrap;margin-top:.2rem;">
            ${b.priority?`<span class="priority-badge">⭐ Prioridad</span>`:''}
            ${bFmt?`<span class="${st.format==='digital'?'format-digital':'format-fisico'}">${st.format==='digital'?'💻 Digital':'📗 Físico'}</span>`:''}
            ${bG&&st.genre?`<span class="genre-badge">🏷️ ${st.genre}</span>`:''}
          </div>
          <div class="book-meta">
            ${bA&&st.author?`<span>✍️ ${st.author}</span>`:''}
            ${bSaga&&st.saga?`<span>📚 ${st.saga}</span>`:''}
            ${bPg&&st.pages?`<span>📄 ${st.pages} pág.</span>`:''}
          </div>
          ${st.url?`<a class="card-link" href="${st.url}" target="_blank" rel="noopener" onclick="event.stopPropagation()">🔗 Ir a leer</a>`:''}
        </div>
      </div>
      ${bSt?`<div class="status-row">${statusBtns}</div>`:''}
      ${st.status==='reading'?(()=>{
        const total=st.pages||0;const cur=st.pagesRead||0;
        const pct=total>0?Math.min(100,Math.round(cur/total*100)):Math.min(100,cur);
        const track=total>0?`<div class="book-progress-track"><div class="book-progress-fill" style="width:${pct}%"></div></div>`:'';
        const maxAttr=total>0?`max="${total}"`:'max="100"';
        const valAttr=total>0?cur:pct;
        const placeholder=total>0?'Págs':'%';
        const label=total>0?`/ ${total} págs`:'';
        return `<div class="book-progress-wrap">${track}<div class="book-progress-row"><span class="book-progress-label">📖 Progreso</span><input class="book-progress-input" type="number" min="0" ${maxAttr} value="${valAttr}" placeholder="${placeholder}" onchange="setBookProgress(${b.id},this.value,${total>0})"><span class="book-progress-label">${label}</span><span class="book-progress-pct">${pct}%</span></div></div>`;
      })():''}

      ${bR?buildRatingBlock(b.id,st,false):''}
      ${bR?favBtnsB:''}
      ${bFd&&st.status==='read'&&st.finishDate?`<div style="font-size:.7rem;color:var(--text3);">✅ Terminado: <input type="date" value="${st.finishDate}" onchange="setBookFinishDate(${b.id},this.value)" style="border:none;background:transparent;color:var(--text3);font-size:.7rem;font-family:'DM Sans',sans-serif;cursor:pointer;"></div>`:''}
      ${(()=>{
        if(!st.releaseDate)return '';
        const rd=new Date(st.releaseDate);rd.setHours(0,0,0,0);
        const today=new Date();today.setHours(0,0,0,0);
        const diff=Math.round((rd-today)/(1000*60*60*24));
        if(diff>0)return `<div style="font-size:.68rem;background:#d1fae5;color:#065f46;border-radius:6px;padding:.18rem .5rem;display:inline-block;margin-top:.15rem;">📦 Sale en ${diff} día${diff!==1?'s':''}</div>`;
        if(diff===0)return `<div style="font-size:.68rem;background:#d1fae5;color:#065f46;border-radius:6px;padding:.18rem .5rem;display:inline-block;margin-top:.15rem;">🎉 ¡Sale hoy!</div>`;
        return '';
      })()}
    </div>`;
  }).join('');
}

function toggleBookTitle(el){el.classList.toggle('expanded');}

function openBookDetailModal(id){
  const b=BOOKS_LIB.find(x=>x.id===id);
  const st=BOOKS_STATE[id];
  if(!b||!st)return;
  document.getElementById('bookDetailTitle').textContent=b.title;
  const sL={unread:'Sin leer',reading:'Leyendo',read:'Leído',paused:'Pausado'};
  const statusColors={unread:'#a78bfa',reading:'#f59e0b',read:'#34d399',paused:'#60a5fa'};
  const stars=[1,2,3,4,5].map(n=>`<span style="font-size:1.1rem;color:${n<=st.rating?'#f59e0b':'var(--border)'};">★</span>`).join('');
  const rows=[
    st.author?['✍️ Autor',st.author]:null,
    st.saga?['📚 Saga',st.saga]:null,
    st.genre?['🏷️ Género',st.genre]:null,
    st.format?['📗 Formato',st.format==='digital'?'💻 Digital':'📗 Físico']:null,
    st.pages?['📄 Páginas',st.pages]:null,
    st.status?['📌 Estado',`<span style="color:${statusColors[st.status]};font-weight:600;">${sL[st.status]}</span>`]:null,
    st.finishDate?['✅ Terminado',st.finishDate]:null,
    st.releaseDate?['📦 Lanzamiento',st.releaseDate]:null,
    b.priority?['⭐ Prioridad','Sí']:null,
    (st.status==='reading'&&st.pagesRead)?['📖 Progreso',st.pages?`${st.pagesRead} / ${st.pages} págs (${Math.round(st.pagesRead/st.pages*100)}%)`:`${Math.min(100,st.pagesRead)}%`]:null,
  ].filter(Boolean);

  const cover=st.cover
    ?`<img src="${st.cover}" style="width:100%;max-height:220px;object-fit:contain;border-radius:10px;margin-bottom:.85rem;cursor:pointer;" title="Toca para cambiar portada" onclick="triggerCoverUpload(${id},'books',true)">`
    :`<div style="width:100%;height:80px;display:flex;align-items:center;justify-content:center;background:var(--p1);border-radius:10px;font-size:1.2rem;gap:.5rem;color:var(--p4);cursor:pointer;margin-bottom:.85rem;" onclick="triggerCoverUpload(${id},'books',true)">📖 <span style="font-size:.8rem;">Toca para añadir portada</span></div>`;

  document.getElementById('bookDetailBody').innerHTML=`
    ${cover}
    ${st.rating?`<div style="margin-bottom:.65rem;">${stars}</div>`:''}
    <table style="width:100%;border-collapse:collapse;font-size:.82rem;">
      ${rows.map(([k,v])=>`<tr>
        <td style="padding:.35rem .5rem .35rem 0;color:var(--text3);white-space:nowrap;vertical-align:top;">${k}</td>
        <td style="padding:.35rem 0;color:var(--text);font-weight:500;">${v}</td>
      </tr>`).join('')}
    </table>
    ${st.synopsis?`<div style="margin-top:.75rem;padding:.65rem;background:var(--p0);border-radius:10px;font-size:.8rem;color:var(--text2);line-height:1.5;"><strong style="display:block;margin-bottom:.3rem;color:var(--p4);">📝 Sinopsis</strong>${st.synopsis}</div>`:''}
    ${st.url?`<a href="${st.url}" target="_blank" rel="noopener" style="display:block;margin-top:.75rem;text-align:center;padding:.45rem;background:var(--p2);border-radius:10px;color:var(--p5);font-size:.82rem;font-weight:600;text-decoration:none;">🔗 Ir a leer</a>`:''}
    <div style="display:flex;gap:.5rem;margin-top:.85rem;">
      <button onclick="closeBookDetailModal();openEditBookModal(${id})" style="flex:1;padding:.45rem;border-radius:10px;border:1.5px solid var(--border);background:var(--p1);color:var(--p4);font-family:'DM Sans',sans-serif;font-size:.8rem;cursor:pointer;">✏️ Editar</button>
    </div>`;
  document.getElementById('bookDetailOverlay').classList.add('open');
}
function closeBookDetailModal(){document.getElementById('bookDetailOverlay').classList.remove('open');}
function setBookStatus(id,s){const st=BOOKS_STATE[id];if(!st)return;st.status=s;if(s==='read'){if(!st.finishDate)st.finishDate=new Date().toISOString().slice(0,10);st.pagesRead=st.pages||0;}else if(s==='unread'){st.pagesRead=0;st.finishDate=null;}saveBooksState();renderBooks();}
function setBookRating(id,n){if(!BOOKS_STATE[id])return;BOOKS_STATE[id].rating=BOOKS_STATE[id].rating===n?0:n;saveBooksState();renderBooks();}
function setBookFinishDate(id,val){if(!BOOKS_STATE[id])return;BOOKS_STATE[id].finishDate=val;saveBooksState();}
function setBookProgress(id,val,isPages){
  const st=BOOKS_STATE[id];if(!st)return;
  const n=parseInt(val)||0;
  if(isPages){st.pagesRead=Math.min(n,st.pages||99999);}
  else{st.pagesRead=n;}
  saveBooksState();renderBooks();
}

function openAddBookModal(){
  ['bTitle','bAuthor','bGenre','bSaga','bUrl'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('bPages').value='';document.getElementById('bFormat').value='fisico';
  document.getElementById('bPriority').checked=false;document.getElementById('bTitleError').style.display='none';
  document.getElementById('bReleaseDate').value='';
  document.getElementById('addBookOverlay').classList.add('open');setTimeout(()=>document.getElementById('bTitle').focus(),300);
}
function closeAddBookModal(){document.getElementById('addBookOverlay').classList.remove('open');}
function confirmAddBook(){
  const title=document.getElementById('bTitle').value.trim();
  if(!title){document.getElementById('bTitleError').style.display='block';return;}
  const newId=Date.now()+Math.floor(Math.random()*9999);
  const rdVal=document.getElementById('bReleaseDate').value;
  BOOKS_LIB.push({id:newId,title,addedAt:new Date().toISOString()});
  BOOKS_STATE[newId]=Object.assign(defaultBookEntry(),{author:document.getElementById('bAuthor').value.trim(),genre:document.getElementById('bGenre').value.trim(),saga:document.getElementById('bSaga').value.trim(),format:document.getElementById('bFormat').value,pages:parseInt(document.getElementById('bPages').value)||0,url:document.getElementById('bUrl').value.trim(),priority:document.getElementById('bPriority').checked,releaseDate:rdVal||null});
  saveBooksLib();saveBooksState();closeAddBookModal();renderBooks();renderTodayBanner();showToast(`📖 "${title}" añadido`);
}

let _editBookCoverData=null;
function handleBookCoverFile(input){
  const file=input.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=e=>{const img=new Image();img.onload=()=>{const maxW=300,maxH=450;let w=img.width,h=img.height;if(w>maxW){h=Math.round(h*maxW/w);w=maxW;}if(h>maxH){w=Math.round(w*maxH/h);h=maxH;}const canvas=document.createElement('canvas');canvas.width=w;canvas.height=h;canvas.getContext('2d').drawImage(img,0,0,w,h);_editBookCoverData=canvas.toDataURL('image/jpeg',.75);showBookCoverPreview(_editBookCoverData);};img.src=e.target.result;};reader.readAsDataURL(file);
}
function previewBookCoverUrl(url){_editBookCoverData=url||null;showBookCoverPreview(url||null);}
function showBookCoverPreview(src){const el=document.getElementById('editBookCoverPreview');el.innerHTML=src?`<img src="${src}" style="height:88px;border-radius:7px;object-fit:cover;border:1.5px solid var(--border);">`:'';}
function removeBookCover(){_editBookCoverData=null;document.getElementById('editBookCoverUrl').value='';document.getElementById('editBookCoverFile').value='';showBookCoverPreview(null);}

function openEditBookModal(id){
  const b=BOOKS_LIB.find(x=>x.id===id);const st=BOOKS_STATE[id];
  if(!b||!st)return;
  _editBookCoverData=st.cover||null;
  document.getElementById('editBookId').value=id;document.getElementById('editBTitle').value=b.title;
  document.getElementById('editBAuthor').value=st.author||'';document.getElementById('editBGenre').value=st.genre||'';
  document.getElementById('editBSaga').value=st.saga||'';document.getElementById('editBFormat').value=st.format||'fisico';
  document.getElementById('editBPages').value=st.pages||'';document.getElementById('editBUrl').value=st.url||'';
  document.getElementById('editBPriority').checked=b.priority||false;document.getElementById('editBTitleError').style.display='none';
  document.getElementById('editBookCoverUrl').value=(st.cover&&!st.cover.startsWith('data:'))?st.cover:'';
  document.getElementById('editBookCoverFile').value='';showBookCoverPreview(st.cover||null);
  document.getElementById('editBReleaseDate').value=st.releaseDate||'';
  document.getElementById('editBookOverlay').classList.add('open');setTimeout(()=>document.getElementById('editBTitle').focus(),300);
}
function closeEditBookModal(){document.getElementById('editBookOverlay').classList.remove('open');_editBookCoverData=null;}
function confirmEditBook(){
  const id=Number(document.getElementById('editBookId').value);
  const title=document.getElementById('editBTitle').value.trim();
  if(!title){document.getElementById('editBTitleError').style.display='block';return;}
  const b=BOOKS_LIB.find(x=>x.id===id);b.title=title;b.priority=document.getElementById('editBPriority').checked;
  const rdVal=document.getElementById('editBReleaseDate').value;
  Object.assign(BOOKS_STATE[id],{author:document.getElementById('editBAuthor').value.trim(),genre:document.getElementById('editBGenre').value.trim(),saga:document.getElementById('editBSaga').value.trim(),format:document.getElementById('editBFormat').value,pages:parseInt(document.getElementById('editBPages').value)||0,url:document.getElementById('editBUrl').value.trim(),cover:_editBookCoverData||'',releaseDate:rdVal||null});
  saveBooksLib();saveBooksState();closeEditBookModal();renderBooks();renderTodayBanner();showToast(`✨ "${title}" actualizado`);
}
function deleteBookEntry(){
  const id=Number(document.getElementById('editBookId').value);const b=BOOKS_LIB.find(x=>x.id===id);
  if(!confirm(`¿Eliminar "${b.title}"?`))return;
  BOOKS_LIB=BOOKS_LIB.filter(x=>x.id!==id);delete BOOKS_STATE[id];saveBooksLib();saveBooksState();closeEditBookModal();renderBooks();
}
function deleteBookDirect(id){
  const b=BOOKS_LIB.find(x=>x.id===id);if(!confirm(`¿Eliminar "${b.title}"?`))return;
  BOOKS_LIB=BOOKS_LIB.filter(x=>x.id!==id);delete BOOKS_STATE[id];saveBooksLib();saveBooksState();renderBooks();
}

let _calYear=new Date().getFullYear(),_calMonth=new Date().getMonth();
function loadReadingLog(){try{return JSON.parse(localStorage.getItem('tbr-reading-log')||'{}');}catch{return{};}}
function saveReadingLog(log){localStorage.setItem('tbr-reading-log',JSON.stringify(log));}
function renderReadingCalendar(){
  const log=loadReadingLog();const now=new Date();
  const todayStr=`${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
  const year=_calYear,month=_calMonth;
  const MN=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  const DN=['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
  const firstDay=new Date(year,month,1).getDay();
  const daysInMonth=new Date(year,month+1,0).getDate();
  const monthKey=`${year}-${String(month+1).padStart(2,'0')}`;
  let streak=0;const d=new Date();
  while(true){const k=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;if(log[k])streak++;else break;d.setDate(d.getDate()-1);}
  const readDays=Object.keys(log).filter(k=>k.startsWith(monthKey)).length;

  const emptyCells=Array(firstDay).fill(`<div class="cal-day empty"></div>`).join('');
  const daysCells=Array.from({length:daysInMonth},(_,i)=>{
    const day=i+1;
    const k=`${year}-${String(month+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
    const isR=!!log[k];const isT=k===todayStr;
    return `<div class="cal-day${isR?' read':''}${isT?' today':''}" onclick="toggleReadDay('${k}')">${day}</div>`;
  }).join('');
  document.getElementById('readingCalendar').innerHTML=`
    <div class="cal-header">
      <button class="cal-nav" onclick="changeCalMonth(-1)">‹</button>
      <span class="cal-month-label">${MN[month]} ${year}</span>
      <button class="cal-nav" onclick="changeCalMonth(1)">›</button>
    </div>
    <div class="cal-grid">
      <div class="cal-names-row">${DN.map(n=>`<div class="cal-day-name">${n}</div>`).join('')}</div>
      <div class="cal-days-row">${emptyCells}${daysCells}</div>
    </div>
    <div class="cal-streak">📅 ${readDays} día${readDays!==1?'s':''} leídos · 🔥 Racha: ${streak} día${streak!==1?'s':''}</div>`;
