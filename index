function renderStatsByGenre(){
  const c={};
  BOOKS.filter(b=>STATE[b.id]?.status==='read'||STATE[b.id]?.status==='reading').forEach(b=>{
    const st=STATE[b.id];if(st?.genre)st.genre.split(/[,;/]+/).map(g=>g.trim()).filter(Boolean).forEach(g=>{const k=g.toLowerCase();c[k]=(c[k]||0)+1;});
