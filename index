<script>

const DEFAULT_BOOKS=[];

function loadBooks(){try{const s=JSON.parse(localStorage.getItem('tbr-manga-books')||'null');return s||DEFAULT_BOOKS;}catch{return DEFAULT_BOOKS;}}
function saveBooks(){localStorage.setItem('tbr-manga-books',JSON.stringify(BOOKS));}
let BOOKS=loadBooks();

const STATUSES=[
  {key:'unread',label:'Sin leer',cls:'s-unread'},
  {key:'reading',label:'Leyendo',cls:'s-reading'},
  {key:'read',label:'Leído',cls:'s-read'},
  {key:'paused',label:'Pausado',cls:'s-paused'},
];
const EMISSIONS=[
  {key:'ongoing',label:'En curso',cls:'e-ongoing',icon:'🟠'},
  {key:'finished',label:'Finalizado',cls:'e-finished',icon:'✅'},
  {key:'hiatus',label:'En hiatus',cls:'e-hiatus',icon:'⏸'},
  {key:'announced',label:'Por anunciar',cls:'e-announced',icon:'📢'},
];
const WEEK_DAYS=['Lu','Ma','Mi','Ju','Vi','Sá','Do'];
const MONTH_DATES=Array.from({length:31},(_,i)=>i+1);

function defaultEntry(){return{status:'unread',rating:0,cry:0,laugh:0,spicy:0,favorite:false,hated:false,chapCur:0,chapTotal:0,extraCur:0,extraTotal:0,emission:'',freq:'week',updateDays:[],type:'manhwa',url:'',cover:'',author:'',genre:'',synopsis:'',sinopsis:'',scheduleLocked:false,finishDate:null,hiatusReturn:null,restActive:0,restPause:0,restStart:null};}
function loadState(){
  try{
    const s=JSON.parse(localStorage.getItem('tbr-manga-v5')||'{}');
    const out={};
    BOOKS.forEach(b=>{out[b.id]=Object.assign(defaultEntry(),s[b.id]||{});});
    return out;
  }catch{const o={};BOOKS.forEach(b=>{o[b.id]=defaultEntry();});return o;}
}
let STATE=loadState();
let filter='all',view='2',spinning=false;
let dark=localStorage.getItem('tbr-manga-dark')==='1';

function applyTheme(){
  document.documentElement.setAttribute('data-theme',dark?'dark':'light');
  const icon=dark?'☀️':'🌙';
  document.getElementById('themeBtn').textContent=icon;
  const tb=document.getElementById('themeBtnBooks');if(tb)tb.textContent=icon;
}
function toggleTheme(){
  dark=!dark;
  localStorage.setItem('tbr-manga-dark',dark?'1':'0');
  applyTheme();
  const saved=localStorage.getItem('tbr-palette')||'rose';
  applyPalette(saved,null);
}
applyTheme();
function save(){localStorage.setItem('tbr-manga-v5',JSON.stringify(STATE));}

const NOW=new Date();
const TODAY_WEEKDAY=WEEK_DAYS[NOW.getDay()===0?6:NOW.getDay()-1];
const TODAY_DATE=NOW.getDate();

function updatesToday(st){
  if(!st.updateDays||!st.updateDays.length)return false;
  if(st.emission==='hiatus'){
    if(!st.hiatusReturn)return false;
    const ret=new Date(st.hiatusReturn);ret.setHours(0,0,0,0);
    const tod=new Date();tod.setHours(0,0,0,0);
    if(tod<ret)return false;
  }

  if(st.restActive>0&&st.restPause>0&&st.restStart){
    const start=new Date(st.restStart);start.setHours(0,0,0,0);
    const today=new Date();today.setHours(0,0,0,0);
    const diffDays=Math.floor((today-start)/(1000*60*60*24));
    if(diffDays>=0){
      const cycleLen=(st.restActive+st.restPause)*7;
      const posInCycle=diffDays%cycleLen;
      if(posInCycle>=st.restActive*7)return false;
    }
  }
  if(st.freq==='week') return st.updateDays.includes(TODAY_WEEKDAY);
  return st.updateDays.map(Number).includes(TODAY_DATE);
}

function getTodayKey(){const n=new Date();return `${n.getFullYear()}-${n.getMonth()+1}-${n.getDate()}`;}
function getDismissedToday(){
  try{const d=JSON.parse(localStorage.getItem('tbr-dismissed-today')||'{}');
  if(d.date!==getTodayKey())return[];return d.ids||[];}catch{return[];}
}
function dismissToday(id){
  const dismissed=getDismissedToday();
  if(!dismissed.includes(id))dismissed.push(id);
  localStorage.setItem('tbr-dismissed-today',JSON.stringify({date:getTodayKey(),ids:dismissed}));
}
function getPendingUpdates(){
  try{
    const raw=JSON.parse(localStorage.getItem('tbr-pending-updates')||'{}');
    const today=getTodayKey();
    const pending=raw.pending||[];
    return pending.filter(p=>p.date!==today);
  }catch{return[];}
}
function savePendingUpdates(list){
  localStorage.setItem('tbr-pending-updates',JSON.stringify({pending:list}));
}
function markPendingDone(id){
  const list=getPendingUpdates().filter(p=>p.id!==id);
  savePendingUpdates(list);
}

function renderTodayBanner(){
  const dismissed=getDismissedToday();
  const today=getTodayKey();
  const todayDate=new Date();todayDate.setHours(0,0,0,0);

  const items=BOOKS.filter(b=>{
    const st=STATE[b.id];
    return (st.emission==='ongoing'||st.emission==='hiatus')&&updatesToday(st)&&!dismissed.includes(b.id);
  });

  const releases=BOOKS_LIB.filter(b=>{
    const st=BOOKS_STATE[b.id];
    if(!st.releaseDate)return false;
    const rd=new Date(st.releaseDate);rd.setHours(0,0,0,0);
    return rd<=todayDate&&!dismissed.includes(`rel-${b.id}`);
  });

  const existingPending=getPendingUpdates();
  const pendingIds=new Set(existingPending.map(p=>p.id));
  const newPending=[...existingPending];
  items.forEach(b=>{if(!pendingIds.has(b.id))newPending.push({id:b.id,date:today});});
  savePendingUpdates(newPending);
  const pending=getPendingUpdates();

  const badge=document.getElementById('todayCount');
  const badgeB=document.getElementById('todayCountBooks');
  const btn=document.getElementById('todayTabBtn');
  const btns=document.querySelectorAll('.hdr-today-btn');
  const total=items.length+pending.length+releases.length;
  if(badge)badge.textContent=total;
  if(badgeB)badgeB.textContent=total||'';
  btns.forEach(b=>{total>0?b.classList.add('has-updates'):b.classList.remove('has-updates');});
  const dateEl=document.getElementById('todayPanelDate');
  if(dateEl)dateEl.textContent=new Date().toLocaleDateString('es-ES',{weekday:'long',year:'numeric',month:'long',day:'numeric'});

  const list=document.getElementById('todayList');
  if(!list)return;

  const makeItem=(b,isPending)=>{
    const st=STATE[b.id];
    const chapNum=st.chapCur>0?`Cap. ${st.chapCur} → ${st.chapCur+1}`:'Inicio';
    return `<div class="today-item${isPending?' pending':''}">
      <span class="today-dot${isPending?' pending':''}"></span>
      <div class="today-chap-info">
        <strong>${b.title}</strong>
        <span class="today-chap-num">📖 ${chapNum}</span>
        ${isPending?`<span class="today-pending-tag">⏳ Pendiente</span>`:''}
      </div>
      <button class="today-chap-btn" onclick="addChapFromToday(${b.id})" title="Marcar capítulo leído">＋</button>
    </div>`;
  };

  const makeReleaseItem=(b)=>{
    const st=BOOKS_STATE[b.id];
    const rd=new Date(st.releaseDate);
    const isToday=rd.toDateString()===new Date().toDateString();
    const label=isToday?'🎉 ¡Sale hoy!':`📦 Salió el ${rd.toLocaleDateString('es-ES',{day:'numeric',month:'short'})}`;
    return `<div class="today-item">
      <span class="today-dot" style="background:#34d399;"></span>
      <div class="today-chap-info">
        <strong>${b.title}</strong>
        ${st.author?`<span class="today-chap-num">✍️ ${st.author}</span>`:''}
        <span class="today-pending-tag" style="color:#059669;">${label}</span>
      </div>
      <button class="today-chap-btn" style="background:#d1fae5;border-color:#6ee7b7;color:#065f46;" onclick="dismissRelease(${b.id})" title="Ya lo tengo">✓</button>
    </div>`;
  };

  const todayHtml=items.length?`<div class="today-section-label">Hoy</div>`+items.map(b=>makeItem(b,false)).join(''):'';
  const pendingHtml=pending.length?`<div class="today-section-label">Pendientes</div>`+pending.map(p=>{const b=BOOKS.find(x=>x.id===p.id);return b?makeItem(b,true):'';}).filter(Boolean).join(''):'';
  const releasesHtml=releases.length?`<div class="today-section-label">📚 Lanzamientos</div>`+releases.map(b=>makeReleaseItem(b)).join(''):'';

  list.innerHTML=(todayHtml||pendingHtml||releasesHtml)
    ?todayHtml+pendingHtml+releasesHtml
    :`<div class="today-empty">No hay actualizaciones para hoy 🌸</div>`;
}

function dismissRelease(id){
  const dismissed=getDismissedToday();
  const key=`rel-${id}`;
  if(!dismissed.includes(key))dismissed.push(key);
  localStorage.setItem('tbr-dismissed-today',JSON.stringify({date:getTodayKey(),ids:dismissed}));
  renderTodayBanner();
  showToast('📚 ¡Lanzamiento marcado!');
}
function toggleTodayPanel(){document.getElementById('todayPanel').classList.toggle('show');}
function closeTodayPanel(){document.getElementById('todayPanel').classList.remove('show');}
function addChapFromToday(id){
  const st=STATE[id];
  const max=st.chapTotal>0?st.chapTotal:Infinity;
  if(st.chapCur<max){
    st.chapCur++;
    save();
    const el=document.getElementById(`chap-cur-${id}`);
    if(el){el.value=st.chapCur;el.classList.remove('chap-bump');void el.offsetWidth;el.classList.add('chap-bump');}
    const pct=st.chapTotal>0?Math.min(100,Math.round(st.chapCur/st.chapTotal*100)):0;
    const bar=document.getElementById(`chap-bar-${id}`);if(bar)bar.style.width=pct+'%';
    const pctEl=document.getElementById(`chap-pct-${id}`);if(pctEl)pctEl.textContent=pct+'%';
    if(st.chapTotal>0&&st.chapCur>=st.chapTotal){st.status='read';save();confettiPop();render();}
    dismissToday(id);
    markPendingDone(id);
    renderTodayBanner();
    showToast(`📖 Cap. ${st.chapCur} leído — ${BOOKS.find(b=>b.id===id)?.title||''}`);
  } else {
    showToast('✅ ¡Ya completaste este manga!');
  }
}

function scheduleDisplay(st){
  if(!st.updateDays||!st.updateDays.length)return '';
  if(st.freq==='week'){
    const order=['Lu','Ma','Mi','Ju','Vi','Sá','Do'];
    return '📅 '+st.updateDays.slice().sort((a,b)=>order.indexOf(a)-order.indexOf(b)).join(' · ');
  }
  return '📅 Días '+st.updateDays.map(Number).sort((a,b)=>a-b).join(', ')+' de cada mes';
}

function showTodayAlert(){
  const items=BOOKS.filter(b=>STATE[b.id].emission==='ongoing'&&updatesToday(STATE[b.id]));
  if(!items.length)return;
  document.getElementById('alertList').innerHTML=items.map(b=>{
    const st=STATE[b.id];
    return `<div class="alert-item"><span class="alert-icon">🌸</span><div class="alert-info"><div class="alert-title">${b.title}</div><div class="alert-meta">${scheduleDisplay(st)}</div></div></div>`;
  }).join('');
  document.getElementById('alertOverlay').classList.add('open');
}
function closeAlert(){document.getElementById('alertOverlay').classList.remove('open');}
function closeAlertOnOverlay(e){if(e.target===document.getElementById('alertOverlay'))closeAlert();}

function updateStats(){
  const c={unread:0,reading:0,read:0,paused:0,ongoing:0,hiatus:0};
  BOOKS.forEach(b=>{
    const st=STATE[b.id];c[st.status]++;
    if(st.emission==='ongoing')c.ongoing++;
    if(st.emission==='hiatus')c.hiatus++;
  });
  const cfg=[
    {key:'unread',e:'📖',l:'TBR',col:'#c4b5fd'},
    {key:'reading',e:'✨',l:'Leyendo',col:'#fcd34d'},
    {key:'read',e:'✅',l:'Leídos',col:'#86efac'},
    {key:'paused',e:'⏸',l:'Pausados',col:'#93c5fd'},
    {key:'ongoing',e:'🟠',l:'En emisión',col:'#fb923c',fk:'emit-ongoing'},
    {key:'hiatus',e:'⏸',l:'En hiatus',col:'#d8b4fe',fk:'emit-hiatus'},
  ];
  document.getElementById('statsRow').innerHTML=cfg.map(x=>
    `<div class="stat-pill" onclick="setFilterDrop('${x.fk||x.key}','${x.l}',null)">
      <span class="stat-pill-num" style="color:${x.col}">${c[x.key]}</span>
      <span class="stat-pill-label">${x.l}</span>
    </div>`
  ).join('');
}

function toggleFilterDrop(){document.getElementById('filterDropMenu').classList.toggle('open');}
function setFilterDrop(f,label,itemEl){
  filter=f;
