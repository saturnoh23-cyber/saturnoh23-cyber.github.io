function shareBingo(id){
  const bingos=loadBingos();
  const b=bingos.find(x=>x.id===id);
  if(!b)return;
  const sz=b.size;
  const cellSize=sz===3?110:sz===4?92:78;
  const pad=6;
  const total=sz*cellSize+(sz+1)*pad;
  const headerH=48;
  const canvas=document.createElement('canvas');
  canvas.width=total;canvas.height=total+headerH;
  const ctx=canvas.getContext('2d');
  const st=getComputedStyle(document.documentElement);
  const bg=st.getPropertyValue('--p1').trim()||'#ffe4ec';
  const p2=st.getPropertyValue('--p2').trim()||'#ffc2d4';
  const p3=st.getPropertyValue('--p3').trim()||'#ff8fab';
  const p5=st.getPropertyValue('--p5').trim()||'#a0395a';
  ctx.fillStyle=bg;ctx.fillRect(0,0,canvas.width,canvas.height);
  ctx.fillStyle=p5;ctx.font='bold 15px serif';ctx.textAlign='center';
  ctx.fillText('🎯 '+b.name,canvas.width/2,28);
  b.cells.forEach((c,i)=>{
    const row=Math.floor(i/sz),col=i%sz;
    const x=pad+col*(cellSize+pad);
    const y=headerH+pad+row*(cellSize+pad);
    ctx.fillStyle=c.marked?p2:'#ffffff';
    ctx.strokeStyle=p3;ctx.lineWidth=1.5;
    const r=7;
    ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+cellSize-r,y);ctx.quadraticCurveTo(x+cellSize,y,x+cellSize,y+r);
    ctx.lineTo(x+cellSize,y+cellSize-r);ctx.quadraticCurveTo(x+cellSize,y+cellSize,x+cellSize-r,y+cellSize);
    ctx.lineTo(x+r,y+cellSize);ctx.quadraticCurveTo(x,y+cellSize,x,y+cellSize-r);
    ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();
    ctx.fill();ctx.stroke();
    if(c.marked){ctx.fillStyle='rgba(255,143,171,0.25)';ctx.fill();}
    ctx.fillStyle=p5;
    const fs=sz===3?9.5:sz===4?8.5:7.5;
    ctx.font=`${fs}px sans-serif`;ctx.textAlign='center';
    const words=(c.marked?'✓ ':'')+c.text;
    const wordsArr=words.split(' ');let line='';const lines=[];
    const maxW=cellSize-8;
    wordsArr.forEach(w=>{
      const test=line?line+' '+w:w;
      if(ctx.measureText(test).width>maxW&&line){lines.push(line);line=w;}
      else line=test;
    });
    if(line)lines.push(line);
    const lh=fs+2;
    const startY=y+cellSize/2-(lines.length-1)*lh/2+fs/2;
    lines.forEach((l,li)=>ctx.fillText(l,x+cellSize/2,startY+li*lh));
  });
  document.getElementById('bingoSharePreview').innerHTML=`<img src="${canvas.toDataURL()}" style="max-width:100%;border-radius:10px;" id="bingoShareImg">`;
  document.getElementById('bingoShareOverlay').classList.add('open');
}
