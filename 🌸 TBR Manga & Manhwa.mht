  60% { transform: scale(1.06); }
  100% { transform: scale(1); opacity: 1; }
}

.close-btn { padding: 0.42rem 1.1rem; border-radius: 40px; border: 1.5px solid var(--border); background: transparent; font-size: 0.78rem; color: var(--text2); cursor: pointer; font-family: "DM Sans", sans-serif; transition: 0.18s; }

.close-btn:hover { border-color: var(--p3); color: var(--p4); }

.empty { text-align: center; padding: 3rem 1rem; color: var(--text3); font-style: italic; font-family: "Playfair Display", serif; }

