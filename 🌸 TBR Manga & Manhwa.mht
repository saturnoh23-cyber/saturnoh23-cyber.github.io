.book-card.list-mode .chapter-section, .book-card.list-mode .schedule-section, .book-card.list-mode .emission-section { order: 5; width: 100%; }

.book-card.list-mode .stars-section { margin-left: auto; }

.overlay { position: fixed; inset: 0px; background: rgba(74, 30, 48, 0.533); backdrop-filter: blur(8px); z-index: 100; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s; }

.overlay.open { opacity: 1; pointer-events: all; }

.modal { background: var(--modal-bg); border-radius: 24px; padding: 2rem 2rem 1.8rem; width: min(420px, 92vw); text-align: center; box-shadow: rgba(0, 0, 0, 0.267) 0px 24px 64px; border: 2px solid var(--border); transform: scale(0.88); transition: transform 0.3s, background 0.3s; }

.overlay.open .modal { transform: scale(1); }

.modal h2 { font-family: "Playfair Display", serif; font-size: 1.5rem; color: var(--text); margin-bottom: 0.25rem; }

.modal .msub { font-size: 0.8rem; color: var(--text3); margin-bottom: 1.3rem; }

.roulette-ring { width: 220px; height: 220px; border-radius: 50%; border: 4px solid var(--p2); margin: 0px auto 1.3rem; position: relative; overflow: hidden; box-shadow: 0 0 0 8px var(--p1),0 8px 32px var(--shadow); }

