@charset "utf-8";

:root { --p0: #fff5f7; --p1: #ffe4ec; --p2: #ffc2d4; --p3: #ff8fab; --p4: #e05f85; --p5: #a0395a; --text: #4a1e30; --text2: #8a4a60; --text3: #b88090; --card: #ffffff; --bg: #fff5f7; --border: #f5d0db; --shadow: #ffc2d430; --toolbar: #ffffffcc; --input-bg: #ffffff; --modal-bg: #ffffff; --progress-track: #fde8ed; }

[data-theme="dark"] { --p0: #1a0d12; --p1: #2d1520; --p2: #5a2a3a; --p3: #c06080; --p4: #e07090; --p5: #f0a0b8; --text: #f5d0db; --text2: #d4909f; --text3: #906070; --card: #261218; --bg: #1a0d12; --border: #3d1f28; --shadow: #00000050; --toolbar: #1a0d12cc; --input-bg: #261218; --modal-bg: #261218; --progress-track: #3d1f28; }

* { margin: 0px; padding: 0px; box-sizing: border-box; }

body { font-family: "DM Sans", sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; transition: background 0.35s, color 0.35s; }

body::before { content: ""; position: fixed; inset: 0px; pointer-events: none; z-index: 0; background: radial-gradient(70% 50% at 0% 0%, rgba(255, 214, 229, 0.19) 0%, transparent 60%), radial-gradient(50% 50% at 100% 100%, rgba(255, 194, 212, 0.125) 0%, transparent 60%); transition: opacity 0.35s; }

[data-theme="dark"] body::before { opacity: 0.25; }

.wrap { max-width: 1400px; margin: 0px auto; padding: 1.5rem 1.5rem 5rem; position: relative; z-index: 1; }

header { text-align: center; margin-bottom: 1.6rem; padding: 2rem 1.5rem 1.6rem; background: linear-gradient(150deg,var(--p1),var(--p0)); border-radius: 24px; border: 1.5px solid var(--border); box-shadow: 0 8px 32px var(--shadow); animation: 0.5s ease 0s 1 normal both running fadeUp; position: relative; }

.theme-toggle { position: absolute; top: 1rem; right: 1rem; width: 38px; height: 38px; border-radius: 50%; border: 1.5px solid var(--border); background: var(--card); cursor: pointer; font-size: 1.1rem; display: flex; align-items: center; justify-content: center; transition: 0.2s; box-shadow: 0 2px 8px var(--shadow); }

.theme-toggle:hover { transform: rotate(20deg) scale(1.1); }

header h1 { font-family: "Playfair Display", serif; font-size: 1.9rem; font-weight: 600; color: var(--text); margin-bottom: 0.2rem; }

header .sub { font-size: 0.82rem; color: var(--text3); font-style: italic; }

.stats-row { display: flex; gap: 0.5rem; justify-content: center; margin-top: 1rem; flex-wrap: wrap; }

.stat-pill { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 0.28rem 0.85rem; font-size: 0.73rem; color: var(--text2); display: flex; align-items: center; gap: 0.3rem; transition: background 0.3s, border 0.3s; }

.stat-dot { width: 7px; height: 7px; border-radius: 50%; }

.today-tab-btn { display: flex; align-items: center; gap: 0.45rem; padding: 0.48rem 1rem; border-radius: 40px; border: 1.5px solid var(--p2); background: var(--p1); color: var(--p4); font-family: "DM Sans", sans-serif; font-size: 0.8rem; font-weight: 500; cursor: pointer; transition: 0.2s; white-space: nowrap; position: relative; }

.today-tab-btn:hover { background: var(--p2); border-color: var(--p3); }

.today-tab-btn.has-updates { background: linear-gradient(135deg,var(--p3),var(--p4)); border-color: transparent; color: rgb(255, 255, 255); box-shadow: rgba(255, 143, 171, 0.267) 0px 3px 12px; }

.today-badge { background: rgb(255, 255, 255); color: var(--p4); border-radius: 20px; font-size: 0.68rem; font-weight: 700; padding: 0.05rem 0.4rem; min-width: 18px; text-align: center; }

.today-tab-btn.has-updates .today-badge { background: rgba(255, 255, 255, 0.9); color: rgb(224, 95, 133); }

.today-panel { display: none; background: linear-gradient(135deg,var(--p1),#fff8fb); border: 1.5px solid var(--p2); border-radius: 16px; padding: 1rem 1.2rem; margin-bottom: 1.2rem; animation: 0.3s ease 0s 1 normal both running fadeUp; }

.today-panel.show { display: block; }

.today-panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.7rem; }

.today-panel-title { font-family: "Playfair Display", serif; font-size: 1rem; color: var(--p4); }

.today-panel-date { font-size: 0.75rem; color: var(--text3); font-style: italic; }

.today-panel-close { background: none; border: none; cursor: pointer; font-size: 1rem; color: var(--text3); padding: 0.1rem 0.3rem; border-radius: 6px; transition: color 0.15s; }

.today-panel-close:hover { color: var(--p4); }

.today-empty { font-size: 0.82rem; color: var(--text3); font-style: italic; padding: 0.3rem 0px; }

.today-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.83rem; color: var(--text); padding: 0.3rem 0px; border-bottom: 1px solid var(--border); }

.today-item:last-child { border-bottom: none; }

.today-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--p3); flex-shrink: 0; }

.alert-overlay { position: fixed; inset: 0px; background: rgba(74, 30, 48, 0.4); backdrop-filter: blur(6px); z-index: 200; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s; }

.alert-overlay.open { opacity: 1; pointer-events: all; }

