}

.book-card { background: var(--card); border: 1.5px solid var(--border); border-radius: 16px; padding: 0.85rem; display: flex; flex-direction: column; gap: 0.5rem; transition: transform 0.2s, box-shadow 0.2s, background 0.3s, border 0.3s; animation: 0.35s ease 0s 1 normal both running fadeUp; position: relative; overflow: hidden; }

