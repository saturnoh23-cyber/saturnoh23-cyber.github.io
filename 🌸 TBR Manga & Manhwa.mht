.stars-label { font-size: 0.65rem; color: var(--text3); margin-bottom: 0.2rem; }

.stars-row { display: flex; gap: 0.1rem; }

.star { font-size: 1.1rem; cursor: pointer; transition: transform 0.15s, filter 0.15s, opacity 0.15s; filter: grayscale(1); opacity: 0.25; user-select: none; }

