.view-btn.active { background: var(--p2); border-color: var(--p2); }

.raffle-btn { padding: 0.48rem 1rem; border-radius: 40px; border: none; background: linear-gradient(135deg,var(--p3),var(--p4)); color: rgb(255, 255, 255); font-family: "DM Sans", sans-serif; font-size: 0.8rem; font-weight: 500; cursor: pointer; box-shadow: rgba(255, 143, 171, 0.267) 0px 3px 12px; transition: 0.2s; white-space: nowrap; }

