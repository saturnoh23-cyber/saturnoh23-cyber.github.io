.roulette-title { font-family: "Playfair Display", serif; font-size: 0.88rem; font-weight: 600; color: var(--text); text-align: center; line-height: 1.3; }

.roulette-ring::after { content: "▼"; position: absolute; top: 5px; left: 50%; transform: translateX(-50%); color: var(--p4); font-size: 1rem; z-index: 10; }

.spin-btn { padding: 0.6rem 1.8rem; border-radius: 40px; border: none; background: linear-gradient(135deg,var(--p3),var(--p4)); color: rgb(255, 255, 255); font-family: "DM Sans", sans-serif; font-size: 0.88rem; font-weight: 500; cursor: pointer; box-shadow: rgba(255, 143, 171, 0.267) 0px 4px 16px; transition: 0.2s; margin-bottom: 0.9rem; }

.spin-btn:hover { transform: translateY(-2px); }

.spin-btn:disabled { opacity: 0.45; cursor: not-allowed; transform: none; }

.result-box { background: var(--p1); border: 1.5px solid var(--p2); border-radius: 14px; padding: 0.85rem 1.1rem; margin-bottom: 0.9rem; min-height: 48px; display: flex; align-items: center; justify-content: center; font-family: "Playfair Display", serif; font-size: 0.95rem; color: var(--text); font-style: italic; }

.result-box.pop { animation: 0.4s ease 0s 1 normal none running pop; }

