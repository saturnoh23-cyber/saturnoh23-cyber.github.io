.schedule-section { }

.freq-toggle { display: flex; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; width: fit-content; }

.freq-btn { padding: 0.18rem 0.55rem; font-size: 0.65rem; border: none; cursor: pointer; font-family: "DM Sans", sans-serif; background: transparent; color: var(--text3); transition: 0.15s; white-space: nowrap; }

.freq-btn.active { background: var(--p2); color: var(--text); }

.days-grid { display: flex; gap: 0.22rem; flex-wrap: wrap; margin-top: 0.3rem; }

.day-chip { width: 30px; height: 26px; border-radius: 8px; border: 1px solid var(--border); background: var(--input-bg); color: var(--text3); font-size: 0.65rem; font-weight: 500; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.15s; user-select: none; }

.day-chip:hover { border-color: var(--p3); color: var(--p4); }

.day-chip.active { background: linear-gradient(135deg,var(--p2),var(--p3)); border-color: transparent; color: rgb(255, 255, 255); }

.date-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.18rem; margin-top: 0.3rem; }

.date-chip { height: 24px; border-radius: 6px; border: 1px solid var(--border); background: var(--input-bg); color: var(--text3); font-size: 0.62rem; font-weight: 500; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.15s; user-select: none; }

.date-chip:hover { border-color: var(--p3); color: var(--p4); }

.date-chip.active { background: linear-gradient(135deg,var(--p3),var(--p4)); border-color: transparent; color: rgb(255, 255, 255); font-weight: 600; }

.date-chip.today-date { border-color: var(--p3); color: var(--p4); }

.schedule-display { font-size: 0.68rem; color: var(--p4); font-weight: 500; margin-top: 0.3rem; min-height: 0.9rem; line-height: 1.4; }

.chapter-label { font-size: 0.65rem; color: var(--text3); margin-bottom: 0.3rem; display: flex; justify-content: space-between; }

.chapter-label span { color: var(--p4); font-weight: 500; }

.progress-bar-wrap { height: 6px; background: var(--progress-track); border-radius: 10px; overflow: hidden; margin-bottom: 0.35rem; }

.progress-bar-fill { height: 100%; border-radius: 10px; background: linear-gradient(90deg,var(--p3),var(--p4)); transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1); }

