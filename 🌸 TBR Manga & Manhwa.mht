.card-cover { width: 100%; height: 160px; border-radius: 10px; object-fit: cover; background: var(--p1); border: 1.5px solid var(--border); display: block; cursor: pointer; transition: opacity 0.2s; }

.card-cover:hover { opacity: 0.85; }

.cover-placeholder { width: 100%; height: 160px; border-radius: 10px; background: linear-gradient(135deg,var(--p1),var(--p0)); border: 2px dashed var(--p2); display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: pointer; transition: 0.2s; gap: 0.3rem; }

.cover-placeholder:hover { background: var(--p1); border-color: var(--p3); }

.cover-placeholder span { font-size: 1.4rem; }

.cover-placeholder p { font-size: 0.63rem; color: var(--text3); text-align: center; padding: 0px 0.4rem; }

.cover-input { display: none; }

.book-card.list-mode .card-cover, .book-card.list-mode .cover-placeholder { width: 50px; height: 72px; flex-shrink: 0; border-radius: 7px; }

.book-card.list-mode .cover-placeholder span { font-size: 0.9rem; }

.book-card.list-mode .cover-placeholder p { display: none; }

.extras-section { margin-top: 0.5rem; }

.extras-label { font-size: 0.65rem; color: var(--text3); margin-bottom: 0.28rem; display: flex; justify-content: space-between; }

.extras-label span { color: rgb(160, 96, 208); font-weight: 500; }

.extras-bar-wrap { height: 5px; background: var(--progress-track); border-radius: 10px; overflow: hidden; margin-bottom: 0.32rem; }

.extras-bar-fill { height: 100%; border-radius: 10px; background: linear-gradient(90deg, rgb(192, 144, 224), rgb(144, 80, 192)); transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1); }

[data-theme="dark"] .extras-bar-fill { background: linear-gradient(90deg, rgb(128, 64, 176), rgb(96, 32, 160)); }

.entry-row { background: var(--p0); border: 1.5px solid var(--border); border-radius: 14px; padding: 0.9rem 1rem; margin-bottom: 0.7rem; position: relative; }

.entry-row-num { font-size: 0.68rem; color: var(--text3); font-style: italic; margin-bottom: 0.55rem; }

.entry-remove { position: absolute; top: 0.65rem; right: 0.65rem; width: 22px; height: 22px; border-radius: 50%; border: 1px solid var(--border); background: var(--card); color: var(--text3); font-size: 0.7rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.15s; }

.entry-remove:hover { background: rgb(254, 226, 226); border-color: rgb(252, 165, 165); color: rgb(220, 38, 38); }

.entry-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }

.add-field textarea { width: 100%; padding: 0.5rem 0.85rem; border: 1.5px solid var(--border); border-radius: 12px; background: var(--input-bg); color: var(--text); font-family: "DM Sans", sans-serif; font-size: 0.83rem; outline: none; transition: border-color 0.2s, background 0.3s; resize: vertical; min-height: 60px; }

.add-field textarea:focus { border-color: var(--p3); }

.add-field textarea::placeholder { color: var(--text3); }

.add-more-btn { width: 100%; padding: 0.48rem; border-radius: 12px; border: 1.5px dashed var(--p2); background: transparent; color: var(--p4); font-family: "DM Sans", sans-serif; font-size: 0.82rem; cursor: pointer; transition: 0.18s; margin-bottom: 0.9rem; }

.add-more-btn:hover { background: var(--p1); }

.card-link { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.68rem; color: var(--p4); text-decoration: none; border: 1px solid var(--p2); border-radius: 20px; padding: 0.15rem 0.55rem; background: var(--p1); transition: 0.15s; margin-top: 0.1rem; width: fit-content; }

.card-link:hover { background: var(--p2); }

.type-badge { font-size: 0.6rem; padding: 0.1rem 0.45rem; border-radius: 20px; border: 1px solid; white-space: nowrap; display: inline-flex; align-items: center; gap: 0.15rem; margin-top: 0.2rem; width: fit-content; }

.type-manga { background: rgb(255, 240, 249); color: rgb(192, 38, 160); border-color: rgb(240, 171, 220); }

.type-manhwa { background: rgb(255, 245, 240); color: rgb(192, 80, 0); border-color: rgb(245, 192, 160); }

.type-novel { background: rgb(240, 244, 255); color: rgb(48, 80, 192); border-color: rgb(176, 192, 240); }

[data-theme="dark"] .type-manga { background: rgb(42, 5, 32); color: rgb(224, 96, 192); border-color: rgb(128, 32, 96); }

[data-theme="dark"] .type-manhwa { background: rgb(42, 21, 0); color: rgb(224, 112, 32); border-color: rgb(128, 64, 16); }

[data-theme="dark"] .type-novel { background: rgb(10, 16, 48); color: rgb(96, 128, 224); border-color: rgb(48, 64, 128); }

.filter-group { display: flex; align-items: center; gap: 0.35rem; flex-wrap: wrap; }

.filter-sep { width: 1px; height: 18px; background: var(--border); flex-shrink: 0; }

.chap-plus { width: 26px; height: 26px; border-radius: 50%; border: 1.5px solid var(--p2); background: var(--p1); color: var(--p4); font-size: 1rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.18s; flex-shrink: 0; line-height: 1; user-select: none; }

.chap-plus:hover { background: var(--p2); border-color: var(--p3); transform: scale(1.15); }

.chap-plus:active { transform: scale(0.95); }

.chap-bump { animation: 0.25s ease 0s 1 normal none running bump; }

@keyframes bump { 
  0% { transform: scale(1); }
  50% { transform: scale(1.3); }
  100% { transform: scale(1); }
}

.delete-btn { width: 28px; height: 28px; border-radius: 50%; border: 1px solid var(--border); background: var(--card); color: var(--text3); font-size: 0.75rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.18s; }

.delete-btn:hover { background: rgb(254, 226, 226); border-color: rgb(252, 165, 165); color: rgb(220, 38, 38); }

.card-actions { position: absolute; bottom: 0.7rem; right: 0.7rem; display: flex; gap: 0.3rem; opacity: 0; transition: opacity 0.18s; }

.book-card:hover .card-actions { opacity: 1; }

.main-tabs { display: flex; gap: 0.5rem; margin-bottom: 1.4rem; border-bottom: 2px solid var(--border); padding-bottom: 0px; }

.main-tab { padding: 0.55rem 1.4rem; border-radius: 12px 12px 0px 0px; border: 1.5px solid transparent; background: none; font-family: "DM Sans", sans-serif; font-size: 0.88rem; font-weight: 500; color: var(--text2); cursor: pointer; transition: 0.2s; margin-bottom: -2px; }

.main-tab:hover { color: var(--p4); background: var(--p1); }

.main-tab.active { background: var(--card); border-top-color: ; border-right-color: ; border-left-color: ; border-bottom-color: var(--card); color: var(--p4); font-weight: 600; }

.tab-section { display: none; }

.tab-section.active { display: block; }

.book-card.book-mode { border-top: 3px solid rgb(167, 139, 250); }

.genre-badge { font-size: 0.6rem; padding: 0.1rem 0.45rem; border-radius: 20px; border: 1px solid rgb(221, 214, 254); background: rgb(245, 243, 255); color: rgb(124, 58, 237); white-space: nowrap; }

[data-theme="dark"] .genre-badge { background: rgb(45, 27, 105); color: rgb(196, 181, 253); border-color: rgb(76, 29, 149); }

.format-fisico { font-size: 0.6rem; padding: 0.1rem 0.45rem; border-radius: 20px; background: rgb(240, 253, 244); color: rgb(22, 101, 52); border: 1px solid rgb(187, 247, 208); white-space: nowrap; }

.format-digital { font-size: 0.6rem; padding: 0.1rem 0.45rem; border-radius: 20px; background: rgb(239, 246, 255); color: rgb(30, 64, 175); border: 1px solid rgb(191, 219, 254); white-space: nowrap; }

[data-theme="dark"] .format-fisico { background: rgb(5, 46, 22); color: rgb(134, 239, 172); border-color: rgb(20, 83, 45); }

[data-theme="dark"] .format-digital { background: rgb(12, 26, 58); color: rgb(147, 197, 253); border-color: rgb(30, 58, 138); }

.book-meta { font-size: 0.73rem; color: var(--text3); display: flex; flex-direction: column; gap: 0.15rem; margin-top: 0.25rem; }

.book-meta span { display: flex; align-items: center; gap: 0.25rem; }

@keyframes fadeUp { 
  0% { opacity: 0; transform: translateY(12px); }
  100% { opacity: 1; transform: translateY(0px); }
}

.confetti { position: fixed; pointer-events: none; z-index: 200; border-radius: 50%; animation: 1.3s ease-in 0s 1 normal forwards running confettiFall; }

@keyframes confettiFall { 
  0% { transform: translateY(0px) rotate(0deg); opacity: 1; }
  100% { transform: translateY(320px) rotate(720deg); opacity: 0; }
}
