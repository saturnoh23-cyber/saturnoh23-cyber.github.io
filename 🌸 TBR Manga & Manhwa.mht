.add-overlay { position: fixed; inset: 0px; background: rgba(74, 30, 48, 0.467); backdrop-filter: blur(7px); z-index: 150; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s; }

.add-overlay.open { opacity: 1; pointer-events: all; }

.add-modal { background: var(--modal-bg); border-radius: 24px; padding: 1.8rem 2rem 1.6rem; width: min(420px, 92vw); box-shadow: rgba(0, 0, 0, 0.267) 0px 24px 64px; border: 2px solid var(--border); transform: scale(0.9); transition: transform 0.3s, background 0.3s; }

